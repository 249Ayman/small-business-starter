---
/**
 * Footer Component with i18n support
 */
import { brand } from '../config/brand';
import { client } from '../data/client';
import { getLangFromUrl, useTranslations } from '../i18n';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isRTL = lang === 'ar';

const year = new Date().getFullYear();
const siteName = isRTL ? brand.nameAr : brand.name;

const navLinks = [
  { label: t.nav.home,       href: `/${lang}/` },
  { label: t.nav.about,      href: `/${lang}/about` },
  { label: t.nav.activities, href: `/${lang}/activities` },
  { label: t.nav.team,       href: `/${lang}/team` },
  { label: t.nav.contact,    href: `/${lang}/contact` },
];
---

<footer class="bg-dark text-surface/80">
  <div class="mx-auto max-w-site px-4 py-12 sm:px-6 lg:py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand -->
      <div class="sm:col-span-2 lg:col-span-1">
        <a href={`/${lang}/`} class="inline-block">
          <img src="/logo.png" alt={siteName} class="h-12 w-auto brightness-0 invert" />
        </a>
        <p class="mt-3 max-w-xs text-sm leading-relaxed">
          {t.footer.description}
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class:list={[
          'text-sm font-bold uppercase tracking-wider text-white',
          isRTL ? 'font-arabic' : 'font-heading'
        ]}>
          {t.footer.quickLinks}
        </h3>
        <ul class="mt-3 space-y-2">
          {navLinks.map(({ label, href }) => (
            <li>
              <a href={href} class="text-sm transition-colors hover:text-white">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact info -->
      <div>
        <h3 class:list={[
          'text-sm font-bold uppercase tracking-wider text-white',
          isRTL ? 'font-arabic' : 'font-heading'
        ]}>
          {t.footer.contactInfo}
        </h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li class:list={['flex items-center gap-2', isRTL && 'flex-row-reverse']}>
            <svg class="size-4 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <a href={`mailto:${client.email}`} class="transition-colors hover:text-white">
              {client.email}
            </a>
          </li>
          <li class:list={['flex items-center gap-2', isRTL && 'flex-row-reverse']}>
            <svg class="size-4 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`tel:${client.phoneForTel}`} class="transition-colors hover:text-white">
              {client.phoneFormatted}
            </a>
          </li>
          <li class:list={['flex items-center gap-2', isRTL && 'flex-row-reverse']}>
            <svg class="size-4 shrink-0 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            <span>{isRTL ? client.address.cityAr + '، ' + client.address.countryAr : client.address.city + ', ' + client.address.country}</span>
          </li>
        </ul>
      </div>

      <!-- Geographic Scope -->
      <div>
        <h3 class:list={[
          'text-sm font-bold uppercase tracking-wider text-white',
          isRTL ? 'font-arabic' : 'font-heading'
        ]}>
          {t.footer.followUs}
        </h3>
        <p class="mt-3 text-sm leading-relaxed">
          {t.footer.geographic}
        </p>
        <p class="mt-2 text-xs text-surface/60">
          {isRTL ? client.licenseAr : client.license}
        </p>
      </div>
    </div>

    <!-- Copyright -->
    <div class="mt-10 border-t border-surface/10 pt-6 text-center text-sm">
      &copy; {year} {siteName}. {t.footer.rights}
    </div>
  </div>
</footer>
