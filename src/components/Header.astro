---
/**
 * Header Component with i18n support
 */
import { brand } from '../config/brand';
import { client } from '../data/client';
import { getLangFromUrl, useTranslations, getAlternateUrl, languages, type LanguageCode } from '../i18n';
import LanguageSwitcher from './LanguageSwitcher.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isRTL = lang === 'ar';
const siteName = isRTL ? brand.nameAr : brand.name;

const nav = [
  { label: t.nav.home,       href: `/${lang}/` },
  { label: t.nav.about,      href: `/${lang}/about` },
  { label: t.nav.activities, href: `/${lang}/activities` },
  { label: t.nav.team,       href: `/${lang}/team` },
  { label: t.nav.contact,    href: `/${lang}/contact` },
];

const currentPath = Astro.url.pathname;
---

<header
  class="sticky top-0 z-50 w-full border-b border-border bg-background/95 backdrop-blur-sm"
>
  <div class:list={[
    'mx-auto flex max-w-site items-center justify-between px-4 py-3 sm:px-6 sm:py-4',
    isRTL && 'flex-row-reverse'
  ]}>
    <!-- Logo -->
    <a
      href={`/${lang}/`}
      class="flex shrink-0 items-center transition-opacity hover:opacity-90"
      aria-label={siteName}
    >
      <img
        src="/logo.png"
        alt={siteName}
        width={360}
        height={96}
        class="h-14 w-auto max-w-[260px] sm:h-16 sm:max-w-[300px] md:h-[4.75rem] md:max-w-[340px] lg:h-20 lg:max-w-none"
      />
    </a>

    <!-- Desktop nav -->
    <nav class:list={[
      'hidden items-center gap-1 lg:flex',
      isRTL && 'flex-row-reverse'
    ]} aria-label="Primary navigation">
      {nav.map(({ label, href }) => {
        const normalizedCurrent = currentPath.replace(/\/$/, '');
        const normalizedHref = href.replace(/\/$/, '');
        const isActive = normalizedCurrent === normalizedHref || 
          (normalizedHref !== `/${lang}` && normalizedCurrent.startsWith(normalizedHref));
        return (
          <a
            href={href}
            aria-current={isActive ? 'page' : undefined}
            class:list={[
              'rounded-md px-3 py-2 text-sm font-medium transition-colors',
              isActive
                ? 'bg-primary/10 text-primary'
                : 'text-text-muted hover:text-text',
            ]}
          >
            {label}
          </a>
        );
      })}
    </nav>

    <!-- Desktop CTA + Language Switcher -->
    <div class:list={[
      'hidden items-center gap-4 lg:flex',
      isRTL && 'flex-row-reverse'
    ]}>
      <LanguageSwitcher />
      <a
        href={`mailto:${client.email}`}
        class:list={[
          'inline-flex items-center gap-2 text-sm font-semibold text-text hover:text-primary transition-colors',
          isRTL && 'flex-row-reverse'
        ]}
      >
        <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        <span class="hidden xl:inline">{client.email}</span>
        <span class="xl:hidden">{t.header.getInTouch}</span>
      </a>
      <a
        href={`/${lang}/contact`}
        class="inline-flex min-h-[44px] items-center rounded-md bg-primary px-5 py-2.5 text-sm font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
      >
        {t.header.getInTouch}
      </a>
    </div>

    <!-- Mobile menu button -->
    <button
      id="menu-toggle"
      type="button"
      aria-expanded="false"
      aria-controls="mobile-menu"
      class="inline-flex min-h-[44px] min-w-[44px] items-center justify-center rounded-md text-text-muted hover:bg-surface lg:hidden"
    >
      <span class="sr-only">Toggle menu</span>
      <svg id="menu-icon-open" class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-icon-close" class="hidden size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div
    id="mobile-menu"
    class="mobile-menu border-t border-border bg-background lg:hidden"
    aria-hidden="true"
  >
    <div class="mobile-menu-inner px-4 pb-6 pt-2">
      <nav class="mobile-menu-nav flex flex-col gap-1" aria-label="Mobile navigation">
        {nav.map(({ label, href }, index) => {
          const normalizedCurrent = currentPath.replace(/\/$/, '');
          const normalizedHref = href.replace(/\/$/, '');
          const isActive = normalizedCurrent === normalizedHref || 
            (normalizedHref !== `/${lang}` && normalizedCurrent.startsWith(normalizedHref));
          return (
            <a
              href={href}
              class:list={[
                'mobile-menu-item rounded-md px-3 py-3 text-base font-medium transition-colors',
                isActive
                  ? 'bg-primary/10 text-primary'
                  : 'text-text-muted hover:text-text hover:bg-surface',
              ]}
              style={`--menu-item-delay: ${index * 50}ms`}
            >
              {label}
            </a>
          );
        })}
      </nav>

      <div class="mobile-menu-actions mt-4 flex flex-col gap-3 border-t border-border pt-4">
        <div class="mobile-menu-item px-3" style={`--menu-item-delay: ${nav.length * 50}ms`}>
          <LanguageSwitcher />
        </div>
        <a
          href={`mailto:${client.email}`}
          class:list={[
            'mobile-menu-item flex items-center gap-2 px-3 py-2 text-base font-semibold text-text',
            isRTL && 'flex-row-reverse'
          ]}
          style={`--menu-item-delay: ${(nav.length + 1) * 50}ms`}
        >
          <svg class="size-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
          </svg>
          {client.email}
        </a>
        <a
          href={`/${lang}/contact`}
          class="mobile-menu-item flex min-h-[44px] items-center justify-center rounded-md bg-primary px-5 py-3 text-base font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90"
          style={`--menu-item-delay: ${(nav.length + 2) * 50}ms`}
        >
          {t.header.getInTouch}
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .mobile-menu {
    max-height: 0;
    overflow: hidden;
    opacity: 0;
    pointer-events: none;
    transition:
      max-height 0.4s cubic-bezier(0.16, 1, 0.3, 1),
      opacity 0.3s ease;
  }

  .mobile-menu.is-open {
    max-height: 36rem;
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-item {
    opacity: 0;
    transform: translateY(-0.5rem);
    animation: none;
  }

  .mobile-menu.is-open .mobile-menu-item {
    animation: mobileMenuItemIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--menu-item-delay, 0ms);
  }

  @keyframes mobileMenuItemIn {
    from {
      opacity: 0;
      transform: translateY(-0.5rem);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #menu-icon-open,
  #menu-icon-close {
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  #menu-toggle[aria-expanded='true'] #menu-icon-close {
    transform: rotate(90deg);
  }

  @media (prefers-reduced-motion: reduce) {
    .mobile-menu {
      transition: none;
    }

    .mobile-menu.is-open {
      max-height: none;
    }

    .mobile-menu-item,
    .mobile-menu.is-open .mobile-menu-item {
      opacity: 1;
      transform: none;
      animation: none;
    }

    #menu-icon-open,
    #menu-icon-close {
      transition: none;
    }
  }
</style>

<script>
  (() => {
    /** @type {HTMLElement | null} */
    let header = null;
    /** @type {HTMLButtonElement | null} */
    let btn = null;
    /** @type {HTMLElement | null} */
    let menu = null;
    /** @type {HTMLElement | null} */
    let iconOpen = null;
    /** @type {HTMLElement | null} */
    let iconClose = null;

    const activeClasses = ['bg-primary/10', 'text-primary'];
    const inactiveDesktop = ['text-text-muted', 'hover:text-text'];
    const inactiveMobile = ['text-text-muted', 'hover:text-text', 'hover:bg-surface'];

    const isDesktop = () => window.matchMedia('(min-width: 1024px)').matches;

    const setMenuOpen = (nextOpen: boolean) => {
      if (!btn || !menu || !iconOpen || !iconClose) return;
      if (isDesktop()) nextOpen = false;

      btn.setAttribute('aria-expanded', String(nextOpen));
      menu.setAttribute('aria-hidden', String(!nextOpen));
      menu.classList.toggle('is-open', nextOpen);
      iconOpen.classList.toggle('hidden', nextOpen);
      iconClose.classList.toggle('hidden', !nextOpen);
    };

    function syncActiveLinks() {
      if (!header) return;
      const path = window.location.pathname.replace(/\/$/, '') || '/';
      const lang = path.split('/').filter(Boolean)[0] === 'ar' ? 'ar' : 'en';
      const desktopLinks = header.querySelectorAll('nav[aria-label="Primary navigation"] a');
      const mobileLinks = header.querySelectorAll('#mobile-menu nav a');

      desktopLinks.forEach((link) => {
        const href = (link.getAttribute('href') || '').replace(/\/$/, '');
        const isActive =
          href === path ||
          (href !== `/${lang}` && path.startsWith(href));
        link.classList.toggle(activeClasses[0], isActive);
        link.classList.toggle(activeClasses[1], isActive);
        link.classList.toggle(inactiveDesktop[0], !isActive);
        link.classList.toggle(inactiveDesktop[1], !isActive);
        if (isActive) link.setAttribute('aria-current', 'page');
        else link.removeAttribute('aria-current');
      });

      mobileLinks.forEach((link) => {
        const href = (link.getAttribute('href') || '').replace(/\/$/, '');
        const isActive =
          href === path ||
          (href !== `/${lang}` && path.startsWith(href));
        link.classList.toggle(activeClasses[0], isActive);
        link.classList.toggle(activeClasses[1], isActive);
        link.classList.toggle(inactiveMobile[0], !isActive);
        link.classList.toggle(inactiveMobile[1], !isActive);
        link.classList.toggle(inactiveMobile[2], !isActive);
        if (isActive) link.setAttribute('aria-current', 'page');
        else link.removeAttribute('aria-current');
      });
    }

    function initHeader() {
      const headerEl = document.querySelector('header');
      const btnEl = document.getElementById('menu-toggle');
      const menuEl = document.getElementById('mobile-menu');
      const iconOpenEl = document.getElementById('menu-icon-open');
      const iconCloseEl = document.getElementById('menu-icon-close');

      if (!headerEl || !btnEl || !menuEl || !iconOpenEl || !iconCloseEl) return;

      header = /** @type {HTMLElement} */ (headerEl);
      btn = /** @type {HTMLButtonElement} */ (btnEl);
      menu = /** @type {HTMLElement} */ (menuEl);
      iconOpen = /** @type {HTMLElement} */ (iconOpenEl);
      iconClose = /** @type {HTMLElement} */ (iconCloseEl);

      if (header.dataset.menuInit === 'true') {
        setMenuOpen(false);
        syncActiveLinks();
        return;
      }
      header.dataset.menuInit = 'true';

      btn.addEventListener('click', () => {
        if (isDesktop()) return;
        const isOpen = btn?.getAttribute('aria-expanded') === 'true';
        setMenuOpen(!isOpen);
      });

      menu.addEventListener('click', (event) => {
        const target = event.target;
        if (!(target instanceof Element)) return;
        if (target.closest('a[href]')) setMenuOpen(false);
      });

      setMenuOpen(false);
      syncActiveLinks();
    }

    document.addEventListener('astro:before-preparation', () => setMenuOpen(false));
    document.addEventListener('astro:after-swap', () => {
      initHeader();
    });
    window.addEventListener('resize', () => setMenuOpen(false));

    initHeader();
  })();
</script>
