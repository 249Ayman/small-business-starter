---
/**
 * About Section for homepage
 * Brief intro to the organization
 */
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { getLangFromUrl, useTranslations } from '../i18n';
import { aboutImage } from '../config/images';
import AnimateOnScroll from './AnimateOnScroll.astro';

interface Props {
  imageSrc?: ImageMetadata | string;
  imageAlt?: string;
  class?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isRTL = lang === 'ar';

const {
  imageSrc = aboutImage,
  imageAlt = 'SAS Huqooqi team',
} = Astro.props;
---

<section class:list={['py-section', Astro.props.class]}>
  <AnimateOnScroll
    stagger
    class:list={[
      'mx-auto grid max-w-site grid-cols-1 items-center gap-8 px-4 sm:px-6 lg:grid-cols-2 lg:gap-14',
      isRTL && 'lg:grid-flow-dense'
    ]}
  >
    <!-- Image -->
    <div class:list={[
      'overflow-hidden rounded-lg shadow-lg',
      isRTL && 'lg:col-start-2'
    ]}>
      <Image
        src={imageSrc}
        alt={imageAlt}
        width={700}
        height={525}
        loading="lazy"
        decoding="async"
        class="size-full object-cover"
      />
    </div>

    <!-- Content -->
    <div class:list={[
      'space-y-5',
      isRTL && 'lg:col-start-1 lg:row-start-1'
    ]}>
      <span class="text-topper font-bold uppercase tracking-widest text-primary">{t.about.topper}</span>
      <h2 class:list={[
        'text-h2 font-bold text-text',
        isRTL ? 'font-arabic' : 'font-heading'
      ]}>
        {t.about.heading}
      </h2>

      {t.about.story.slice(0, 2).map((paragraph) => (
        <p class="text-text-muted leading-relaxed">{paragraph}</p>
      ))}

      <div class="pt-2">
        <a
          href={`/${lang}/about`}
          class:list={[
            'inline-flex min-h-[44px] items-center gap-2 rounded-md bg-primary px-6 py-3 text-base font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary',
            isRTL && 'flex-row-reverse'
          ]}
        >
          {t.about.cta}
          <svg class:list={['size-4', isRTL && 'rotate-180']} fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </div>
  </AnimateOnScroll>
</section>
