---
/**
 * CTA Section with i18n support
 */
import { getLangFromUrl, useTranslations } from '../i18n';
import AnimateOnScroll from './AnimateOnScroll.astro';

interface Props {
  title?: string;
  description?: string;
  buttonText?: string;
  buttonHref?: string;
  secondaryText?: string;
  secondaryHref?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const isRTL = lang === 'ar';

const {
  title = t.cta.heading,
  description = t.cta.description,
  buttonText = t.cta.button,
  buttonHref = `/${lang}/contact`,
  secondaryText = t.hero.secondary,
  secondaryHref = `/${lang}/activities`,
} = Astro.props;
---

<section class="relative overflow-hidden bg-primary py-16 sm:py-20 lg:py-24">
  <AnimateOnScroll animation="fade-up" class="mx-auto max-w-site px-4 text-center sm:px-6">
    <h2 class:list={[
      'text-h2 font-bold text-primary-fg',
      isRTL ? 'font-arabic' : 'font-heading'
    ]}>
      {title}
    </h2>
    <p class="mx-auto mt-4 max-w-xl text-primary-fg/80 leading-relaxed">
      {description}
    </p>

    <div class:list={[
      'mt-8 flex flex-col items-center gap-4 sm:flex-row sm:justify-center',
      isRTL && 'sm:flex-row-reverse'
    ]}>
      <a
        href={buttonHref}
        class="inline-flex min-h-[44px] items-center justify-center rounded-md bg-background px-8 py-3 text-base font-bold text-primary shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-background"
      >
        {buttonText}
      </a>
      <a
        href={secondaryHref}
        class="inline-flex min-h-[44px] items-center justify-center rounded-md border-2 border-primary-fg/30 px-8 py-3 text-base font-bold text-primary-fg transition-colors hover:border-primary-fg hover:bg-primary-fg/10"
      >
        {secondaryText}
      </a>
    </div>
  </AnimateOnScroll>
</section>
