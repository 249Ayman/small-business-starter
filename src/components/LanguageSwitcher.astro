---
/**
 * Language Switcher Component
 * Toggles between English and Arabic versions
 */
import { getLangFromUrl, getAlternateUrl, languages, type LanguageCode } from '../i18n';

const currentLang = getLangFromUrl(Astro.url);
const otherLang: LanguageCode = currentLang === 'en' ? 'ar' : 'en';
const otherLangConfig = languages[otherLang];
const alternateUrl = getAlternateUrl(Astro.url, otherLang);
---

<a
  href={alternateUrl}
  data-lang-switcher
  class="inline-flex items-center gap-2 rounded-md border border-border bg-background px-3 py-2 text-sm font-medium text-text transition-colors hover:bg-surface hover:border-primary"
  aria-label={`Switch to ${otherLangConfig.name}`}
>
  <svg class="size-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
  </svg>
  <span data-lang-label>{otherLangConfig.name}</span>
</a>

<script>
  const LANG_LABELS = { en: 'English', ar: 'العربية' } as const;

  function getLangFromPath(pathname: string): keyof typeof LANG_LABELS {
    const first = pathname.split('/').filter(Boolean)[0];
    return first === 'ar' ? 'ar' : 'en';
  }

  function getAlternatePath(pathname: string, targetLang: keyof typeof LANG_LABELS): string {
    const parts = pathname.split('/').filter(Boolean);
    if (parts[0] === 'en' || parts[0] === 'ar') {
      parts[0] = targetLang;
      const rest = parts.slice(1).join('/');
      return rest ? `/${targetLang}/${rest}` : `/${targetLang}/`;
    }
    return `/${targetLang}${pathname.startsWith('/') ? pathname : `/${pathname}`}`;
  }

  function syncLanguageSwitchers() {
    const path = window.location.pathname;
    const current = getLangFromPath(path);
    const other = current === 'en' ? 'ar' : 'en';
    const href = getAlternatePath(path, other);
    const label = LANG_LABELS[other];

    document.querySelectorAll('[data-lang-switcher]').forEach((el) => {
      if (!(el instanceof HTMLAnchorElement)) return;
      el.href = href;
      el.setAttribute('aria-label', `Switch to ${label}`);
      const labelEl = el.querySelector('[data-lang-label]');
      if (labelEl) labelEl.textContent = label;
    });
  }

  syncLanguageSwitchers();

  if (!document.documentElement.dataset.langSwitcherInit) {
    document.documentElement.dataset.langSwitcherInit = 'true';
    document.addEventListener('astro:after-swap', syncLanguageSwitchers);
  }
</script>
