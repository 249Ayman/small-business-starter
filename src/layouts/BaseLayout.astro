---
/**
 * Base layout — wraps every page.
 * Supports bilingual English/Arabic with RTL.
 *
 * Astro 6 features used:
 *  • <Font />         — built-in font optimizer from astro.config.mjs fonts array
 *  • <ClientRouter /> — client-side navigation with CSS transition animations
 */
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
import { brand } from '../config/brand';
import { client } from '../data/client';
import { getLangFromUrl, getLanguageConfig, getAlternateUrl, type LanguageCode } from '../i18n';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  schema?: Record<string, unknown>;
  lang?: LanguageCode;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const langConfig = getLanguageConfig(lang);
const isRTL = langConfig.dir === 'rtl';

const {
  title = lang === 'ar' ? brand.nameAr : brand.name,
  description = lang === 'ar' ? brand.descriptionAr : brand.description,
  image = '/og-image.png',
  schema,
} = Astro.props;

const siteName = lang === 'ar' ? brand.nameAr : brand.name;
const pageTitle = title === siteName ? title : `${title} — ${siteName}`;
const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? brand.url);

const alternateEn = new URL(getAlternateUrl(Astro.url, 'en'), Astro.site ?? brand.url);
const alternateAr = new URL(getAlternateUrl(Astro.url, 'ar'), Astro.site ?? brand.url);
---

<html lang={langConfig.code} dir={langConfig.dir} class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <link rel="canonical" href={canonicalURL} />
    <link rel="alternate" hreflang="en" href={alternateEn} />
    <link rel="alternate" hreflang="ar" href={alternateAr} />
    <link rel="alternate" hreflang="x-default" href={alternateEn} />
    
    <title>{pageTitle}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type"        content="website" />
    <meta property="og:url"         content={canonicalURL} />
    <meta property="og:title"       content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image"       content={image} />
    <meta property="og:locale"      content={langConfig.locale} />

    <!-- Twitter Card -->
    <meta name="twitter:card"        content="summary_large_image" />
    <meta name="twitter:title"       content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image"       content={image} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts -->
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body"    preload />
    <Font cssVariable="--font-arabic"  preload />

    <!-- JSON-LD Structured Data -->
    {schema && (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    )}

    <!-- FOUC prevention for dark mode -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem('theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark-mode');
        }
      })();
    </script>

    <slot name="head" />
    <ClientRouter />
  </head>

  <body class:list={[
    'bg-background text-text antialiased',
    isRTL ? 'font-arabic' : 'font-body'
  ]}>
    <a
      class="sr-only focus:not-sr-only focus:absolute focus:z-[99999] focus:bg-primary focus:text-primary-fg focus:px-4 focus:py-2 focus:rounded-md"
      href="#main"
    >
      {isRTL ? 'تخطي إلى المحتوى الرئيسي' : 'Skip to main content'}
    </a>

    <slot name="header" />

    <main id="main">
      <slot />
    </main>

    <slot name="footer" />

    <script>
      function initScrollAnimations() {
        const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const elements = document.querySelectorAll('[data-animate]:not(.is-visible)');

        if (prefersReduced || !('IntersectionObserver' in window)) {
          elements.forEach((el) => el.classList.add('is-visible'));
          return;
        }

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add('is-visible');
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.1,
            rootMargin: '0px 0px -8% 0px',
          }
        );

        elements.forEach((el) => observer.observe(el));
      }

      initScrollAnimations();
      document.addEventListener('astro:after-swap', initScrollAnimations);
    </script>
  </body>
</html>
