---
/**
 * English Activities Page
 * Core activities and target groups
 */
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Banner from '../../components/Banner.astro';
import CoreActivities from '../../components/CoreActivities.astro';
import TargetGroups from '../../components/TargetGroups.astro';
import CTA from '../../components/CTA.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('en');
---

<BaseLayout
  title={t.meta.activitiesTitle}
  description={t.meta.activitiesDescription}
  lang="en"
>
  <Header slot="header" />

  <Banner title={t.nav.activities} />

  <CoreActivities showAll={true} />
  <TargetGroups />

  <CTA />

  <Footer slot="footer" />
</BaseLayout>
