---
/**
 * Arabic Contact Page
 * صفحة الاتصال
 */
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import Banner from '../../../components/Banner.astro';
import AnimateOnScroll from '../../../components/AnimateOnScroll.astro';
import { useTranslations } from '../../../i18n';
import { client } from '../../../data/client';

const t = useTranslations('ar');
---

<BaseLayout
  title={t.meta.contactTitle}
  description={t.meta.contactDescription}
  lang="ar"
>
  <Header slot="header" />

  <Banner title={t.nav.contact} />

  <section class="py-section">
    <div class="mx-auto max-w-site px-4 sm:px-6">
      <AnimateOnScroll animation="fade-up" class="mx-auto mb-12 max-w-2xl text-center">
        <span class="text-topper font-bold uppercase tracking-widest text-primary">{t.contact.topper}</span>
        <h2 class="mt-2 font-arabic text-h2 font-bold text-text">{t.contact.heading}</h2>
        <p class="mt-4 text-text-muted">{t.contact.description}</p>
      </AnimateOnScroll>

      <AnimateOnScroll stagger class="grid gap-8 lg:grid-cols-2 lg:gap-12">
        <!-- Contact Form (RTL order - form first on right) -->
        <div class="rounded-lg border border-border bg-surface p-6 sm:p-8 lg:order-2">
          <h3 class="mb-6 font-arabic text-xl font-semibold text-text">{t.contact.formTitle}</h3>
          <form 
            id="contact-form-ar"
            class="space-y-5"
            data-success-url="/ar/contact/success"
          >
            
            <div>
              <label for="name" class="mb-2 block text-sm font-medium text-text">
                {t.contact.formName}
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="block w-full rounded-md border border-border bg-background px-4 py-3 text-text placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              />
            </div>

            <div>
              <label for="email" class="mb-2 block text-sm font-medium text-text">
                {t.contact.formEmail}
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                dir="ltr"
                class="block w-full rounded-md border border-border bg-background px-4 py-3 text-text placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              />
            </div>

            <div>
              <label for="message" class="mb-2 block text-sm font-medium text-text">
                {t.contact.formMessage}
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="block w-full rounded-md border border-border bg-background px-4 py-3 text-text placeholder:text-text-muted focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
              ></textarea>
            </div>

            <button
              type="submit"
              class="flex w-full min-h-[48px] items-center justify-center rounded-md bg-primary px-6 py-3 text-base font-bold text-primary-fg shadow-sm transition-opacity hover:opacity-90 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary"
            >
              {t.contact.formSubmit}
            </button>
          </form>

          <script>
            const form = document.getElementById('contact-form-ar');
            if (form) {
              form.addEventListener('submit', async (e) => {
                e.preventDefault();
                const formData = new FormData(form as HTMLFormElement);
                const data = Object.fromEntries(formData.entries());
                
                // Option 1: Open email client with pre-filled message
                const subject = encodeURIComponent('رسالة من موقع مركز ساس الحقوقي');
                const body = encodeURIComponent(`الاسم: ${data.name}\nالبريد الإلكتروني: ${data.email}\n\nالرسالة:\n${data.message}`);
                window.location.href = `mailto:saslawyers85@gmail.com?subject=${subject}&body=${body}`;
                
                // Redirect to success page after a short delay
                setTimeout(() => {
                  window.location.href = (form as HTMLFormElement).dataset.successUrl || '/ar/contact/success';
                }, 500);
              });
            }
          </script>
        </div>

        <!-- Contact Info (RTL order - info on left) -->
        <div class="space-y-6 lg:order-1">
          <!-- Email -->
          <div class="flex items-start gap-4 rounded-lg border border-border bg-surface p-6 flex-row-reverse">
            <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
            </div>
            <div class="text-right flex-1">
              <h3 class="font-arabic text-lg font-semibold text-text">{t.contact.email}</h3>
              <a href={`mailto:${client.email}`} class="mt-1 text-text-muted hover:text-primary transition-colors" dir="ltr">
                {client.email}
              </a>
            </div>
          </div>

          <!-- WhatsApp -->
          <div class="flex items-start gap-4 rounded-lg border border-border bg-surface p-6 flex-row-reverse">
            <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-green-500/10 text-green-600">
              <svg class="size-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div class="text-right flex-1">
              <h3 class="font-arabic text-lg font-semibold text-text">{t.contact.whatsapp}</h3>
              <a 
                href={client.whatsappLink} 
                target="_blank" 
                rel="noopener noreferrer"
                class="mt-1 text-text-muted hover:text-green-600 transition-colors"
                dir="ltr"
              >
                {client.phoneFormatted}
              </a>
            </div>
          </div>

          <!-- Location -->
          <div class="flex items-start gap-4 rounded-lg border border-border bg-surface p-6 flex-row-reverse">
            <div class="flex size-12 shrink-0 items-center justify-center rounded-lg bg-primary/10 text-primary">
              <svg class="size-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div class="text-right flex-1">
              <h3 class="font-arabic text-lg font-semibold text-text">{t.contact.location}</h3>
              <p class="mt-1 text-text-muted">
                {client.address.cityAr}، {client.address.countryAr}
              </p>
            </div>
          </div>

          <!-- WhatsApp CTA Button -->
          <a
            href={client.whatsappLink}
            target="_blank"
            rel="noopener noreferrer"
            class="flex min-h-[56px] items-center justify-center gap-3 rounded-lg bg-green-600 px-6 py-4 text-lg font-bold text-white shadow-lg transition-all hover:bg-green-700 hover:shadow-xl flex-row-reverse"
          >
            <svg class="size-6" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            تواصل عبر واتساب
          </a>
        </div>
      </AnimateOnScroll>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
